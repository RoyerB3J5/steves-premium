---
import { Icon } from 'astro-icon/components';

type Translations = typeof import('../i18n/en').default;
type FooterContent = Translations['footer'];
interface Props {
  content?: FooterContent;
}
const { content } = Astro.props as Props;

// Obtener la ruta actual y normalizar el path sin prefijo de idioma
const currentPath = Astro.url.pathname;
// Normalizar: remover idioma y trailing slash
const normalized =
  currentPath.replace(/^\/(en|es)/, '').replace(/\/$/, '') || '/';
// Detectar el idioma actual ('en' o 'es')
const match = currentPath.match(/^\/(en|es)/);
const lang = match ? match[1] : 'en';

const icons = [
  {
    icon: 'mail',
    href: 'https://mail.google.com/mail/?view=cm&fs=1&to=stevepressurewashing@yahoo.com',
  },
  {
    icon: 'map',
    href: 'https://www.google.com/maps/place/Steve%E2%80%99s+Premium+Pressure+Washing/@28.4468394,-81.3521445,10z/data=!3m1!4b1!4m6!3m5!1s0x4d455d5bdd169efd:0xaceecbb61784ad6a!8m2!3d28.4468394!4d-81.3521445!16s%2Fg%2F11spp29g02?entry=ttu&g_ep=EgoyMDI2MDMwOS4wIKXMDSoASAFQAw%3D%3D',
  },
  {
    icon: 'facebook',
    href: 'https://www.facebook.com/p/Steves-Premium-Pressure-Washing-100083189356054/',
  },
  {
    icon: 'instagram',
    href: 'https://www.instagram.com/p/C7Vz_e1Mqwl/?hl=en',
  }
];
---

<footer class="flex flex-col justify-center items-center w-full">
  <div class=" flex justify-center items-center  bg-white w-full">
    <div class="w-full max-w-screen xl:max-w-7xl px-5 xl:px-0 flex flex-col sm:flex-row justify-center sm:justify-between items-center sm:items-start py-20 gap-10 sm:gap-0">
      <div class="flex flex-col justify-center items-center sm:items-start gap-6">
        <img src="/images/logo-2.svg" alt="Logo de Steve's Premium Pressure Washing" width="486" height="88" class="w-full sm:w-70 lg:w-121.5 h-auto" />
        <p set:html={content?.description} class="text-[14px] font-normal leading-[170%] text-paragraph max-w-87.5 lg:max-w-none text-center sm:text-start"></p>
        <div class="flex justify-center items-center gap-4">
          {
            icons.map(item => ( 
              <a href={item.href} class="bg-secondary h-7.75 w-7.75 rounded-full hover:bg-primary group flex justify-center items-center transition-colors duration-300 cursor-pointer">
                <img src={`/images/${item.icon}.svg`} alt="Icono de redes" class='w-4.5 h-4.5 text-white'>
              </a>
            ))
          }
        </div>
      </div>
      <div class="flex flex-col sm:flex-row justify-center items-center sm:items-start gap-10 sm:gap-6 lg:gap-14">
        <div class="flex flex-col justify-center items-center sm:items-start gap-4 order-2 sm:order-1">
          <h3 class="text-secondary text-[14px] font-semibold leading-[160%] ">{content?.service.title}</h3>
          <div class="flex justify-center items-center">
            {
              content?.service.items.map((item) =>( 
                <div class="flex flex-col sm:flex-row justify-center items-center sm:items-start gap-1">
                  <img src={`/images/${item.icon}.svg`} alt={item.title} width="16" height="16" class="w-6 h-6" />
                  <p set:html={item.title} class="text-paragraph text-[14px] font-semibold leading-[160%] text-center sm:text-start"></p>
                </div>
              ))
            }
          </div>
        </div>
        <div class="flex flex-col justify-center items-center sm:items-start gap-4 order-3 sm:order-2">
          <h3 class="text-secondary text-[14px] font-semibold leading-[160%] ">{content?.call.title}</h3>
          <div class="flex justify-center items-center">
            {
              content?.call.items.map((item) =>( 
                <div class="flex flex-col sm:flex-row justify-center items-center sm:items-start gap-1">
                  <img src={`/images/${item.icon}.svg`} alt={item.label} width="16" height="16" class="w-6 h-6" />
                  <a set:html={item.label} href={item.href} class="text-paragraph text-[14px] font-semibold leading-[160%] hover:text-primary transition-all duration-300 ease-in-out"></a>
                </div>
              ))
            }
          </div>
        </div>
        <div class="flex flex-col justify-center items-center sm:items-start gap-4 order-1 sm:order-3">
          <h3 class="text-secondary text-[14px] font-semibold leading-[160%] ">{content?.nav.title}</h3>
          <nav >
            <ul class="flex flex-col justify-center items-center sm:items-start gap-4">
              {
                content?.nav.items.map((item) =>( 
                 <li>
                  <a href={`/${lang}${item.href}`} class="text-paragraph text-[14px] font-normal leading-[170%] hover:text-primary hover:font-medium transition-all duration-300 ease-in-out">{item.label}</a>
                 </li>
                ))
              }
            </ul>
          </nav>
        </div>
      </div>
    </div>
  </div>
  <div
    class="bg-[#E5E5E5] dark:bg-back-dark w-full py-3.5 md:py-4.5 flex justify-center items-center px-5 xl:px-0"
  >
    <div
      class="w-full max-w-screen md:max-w-7xl flex flex-col md:flex-row justify-center md:justify-between items-center gap-2 md:gap-4"
    >
      <a href="https://inkshapegroup.com/en/">
        <img
          src="/images/inkshape.svg"
          alt=" Logo de Inkshape Group"
          width="208"
          height="40"
          class="w-27.5 md:w-34 h-auto block "
        />
      </a>
      <p
        class="text-[10px] md:text-[12px] lg:text-[13px] leading-[170%] md:leading-[120%] text-[#404040] dark:text-paragraph-dark font-normal text-center"
      >
        Copyright © 2026 by <a href="https://inkshapegroup.com"
          >Inkshape Group</a
        > | Privacy | <a href="/">Steve's Premium Pressure Washing</a> | Orlando | Call Now: <a
          href="tel:+14078448104">407-844-8104</a
        >
      </p>
    </div>
  </div>
</footer>
