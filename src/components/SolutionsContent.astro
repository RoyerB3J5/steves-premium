---
type Translations = typeof import('../i18n/en').default;
type SolutionsContent = Translations['servicesPage']['solution'];
interface Props {
  content: SolutionsContent;
}
const { content } = Astro.props as Props;
---
<>
<div class="flex flex-col justify-center items-center gap-4 animation-down">
      <h2 class="text-primary text-[32px] sm:text-[48px] lg:text-[56px] font-medium leading-[110%] capitalize font-title text-center" set:html={content.title}></h2>
      <div class="w-21.5 h-1.5 rounded-sm animation-color-shift"></div>
    </div>
    <div class="w-full grid grid-cols-2 md:grid-cols-4 justify-center items-center gap-4 lg:gap-x-6 lg:gap-y-8.75">
      {
        content.items.map((item,index)=>( 
          <div class={`w-full flex flex-col justify-center items-center overflow-hidden h-full animation-up `}>
            <div class="w-full h-auto aspect-282/180 relative rounded-t-3xl overflow-hidden">
              <img src={`/images/${item.image}.webp`} alt={item.title} width="282" height="180" class="w-full h-full absolute inset-0 object-cover object-center"/>
            </div>
            <div class="flex flex-col justify-start items-center md:items-start py-6 px-4 md:p-5 lg:p-8 gap-2 bg-secondary/5 box-border border-b border-l border-r border-secondary/15 w-full rounded-b-3xl flex-1">
              <h3 class="text-primary text-[14px] font-bold leading-[150%]">{item.title}</h3>
              <p class="text-paragraph text-[14px] leading-[150%] font-normal md:block hidden ">{item.description}</p>
            </div>
          </div>
        ))
      }
    </div>
</>