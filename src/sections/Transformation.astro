---
import { MuxPlayer } from "@mux/mux-player-astro";

type Translations = typeof import("../i18n/en").default;
type TransformationContent = Translations["gallery"]["transformation"];
interface Props {
  content: TransformationContent;
}
const { content } = Astro.props as Props;
---

<style>
  [data-video-modal] {
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.3s ease-in-out,
      visibility 0.3s ease-in-out;
  }

  [data-video-modal].active {
    opacity: 1;
    visibility: visible;
  }

  [data-video-modal].active > div {
    animation: popupEnter 0.3s ease-in-out;
  }

  @keyframes popupEnter {
    from {
      transform: scale(0.9);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>

<section
  class="w-full flex flex-col justify-center items-center pt-10 md:pt-15 pb-30 max-w-screen xl:max-w-7xl px-5 xl:px-0 gap-12 md:gap-16"
>
  <div class="flex flex-col justify-center items-center gap-4 animation-down">
    <h2
      class="text-primary text-[32px] sm:text-[48px] lg:text-[56px] font-medium leading-[110%] capitalize font-title text-center"
      set:html={content.title}
    />
    <div class="w-21.5 h-1.5 rounded-sm animation-color-shift"></div>
  </div>
  <div
    class="w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 justify-center items-center gap-4 lg:gap-x-6 lg:gap-y-8.75"
  >
    {
      content.items.map((item, index) => (
        <div
          data-video-container
          class="w-full flex flex-col justify-center items-center overflow-hidden h-full animation-up"
        >
          <div
            class="w-full h-auto aspect-video relative rounded-t-3xl overflow-hidden video cursor-pointer"
            data-video-trigger
          >
            <img
              src={item.image}
              alt={item.title}
              width="685"
              height="1210"
              class={`w-full h-full absolute inset-0 object-cover -z-20 ${item.position}`}
              decoding="async"
              loading="lazy"
            />
            <div class="w-full h-full bg-black/50 hover:bg-black/30 flex justify-center items-center transition-all duration-300 ease-in-out z-50">
              <img
                src="/images/play.svg"
                alt="Play de Video"
                width="20"
                height="20"
                class="w-12 h-12"
              />
            </div>
          </div>
          <div class="flex flex-col justify-start items-center md:items-start py-6 px-4 md:p-5 lg:p-8 gap-2 bg-secondary/5 box-border border-b border-l border-r border-secondary/15 w-full rounded-b-3xl flex-1">
            <h3 class="text-primary text-[14px] md:text-[20px] font-bold leading-[150%]">
              {item.title}
            </h3>
            <p class="text-paragraph text-[14px] leading-[150%] font-normal md:block hidden ">
              {item.description}
            </p>
          </div>
          <div
            class="fixed w-screen h-screen top-0 left-0 bg-black/70 flex justify-center items-center z-50"
            data-video-modal
          >
            <MuxPlayer
              playbackId={item.video}
              metadata={{
                video_title: "Steve's Premium Pressure Washing",
              }}
              accentColor="#00256c"
              class="aspect-30/53 h-[70%] md:h-[90%] w-auto rounded-lg overflow-hidden bg-transparent "
              poster={item.image}
            />
          </div>
        </div>
      ))
    }
  </div>
</section>
<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const videoTriggers = document.querySelectorAll("[data-video-trigger]");
    const modalStorage = new Map(); // Guardar referencias de modales a contenedores

    videoTriggers.forEach((trigger) => {
      trigger.addEventListener("click", (e) => {
        e.stopPropagation();
        const container = trigger.closest("[data-video-container]");
        const modal = container?.querySelector("[data-video-modal]");
        if (modal) {
          // Guardar referencia del contenedor original
          modalStorage.set(modal, container);
          // Mover el modal al body
          document.body.appendChild(modal);
          modal.classList.add("active");
        }
      });
    });

    // Event listener para los modales usando event delegation
    document.addEventListener("click", (e) => {
      const modal = e.target.closest("[data-video-modal]");
      if (modal && e.target === modal) {
        modal.classList.remove("active");
        // Mover de vuelta al contenedor original
        setTimeout(() => {
          const originalContainer = modalStorage.get(modal);
          if (originalContainer && originalContainer.parentElement) {
            originalContainer.appendChild(modal);
            modalStorage.delete(modal);
          }
        }, 300);
      }
    });
  });
</script>
