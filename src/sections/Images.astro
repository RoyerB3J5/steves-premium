---
type Translations = typeof import('../i18n/en').default;
type SolutionsContent = Translations['gallery']['images'];
interface Props {
  content: SolutionsContent;
}
const { content } = Astro.props as Props;
---
<section class="w-full flex flex-col max-w-screen xl:max-w-7xl px-5 xl:px-0 gap-16 justify-center items-center pt-20 pb-15">
  <div class="flex flex-col justify-center items-center gap-4">
      <h2 class="text-primary text-[56px] font-medium leading-[110%] capitalize font-title text-center" set:html={content.title}></h2>
      <div class="w-21.5 h-1.5 rounded-sm bg-secondary"></div>
  </div>
  <div class="grid grid-cols-4 justify-center items-center gap-6 w-full">
    {
      content.items.map((item) => (
        <div class="w-full h-auto aspect-282/282 relative rounded-3xl overflow-hidden bg-gray-200">
          <img src={`/images/${item}.webp`} alt={`Gallery Image ${item}`} width="384" height="384" class="w-full h-full absolute inset-0 object-cover object-center"/>
        </div>
      ))
    }
  </div>
</section>