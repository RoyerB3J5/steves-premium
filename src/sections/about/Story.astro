---
import Button from "../../components/Button.astro";

type Translations = typeof import("../../i18n/en").default;
type StoryContent = Translations["about"]["story"];
interface Props {
  content: StoryContent;
}
const { content } = Astro.props as Props;
---

<section
  class="w-full max-w-screen xl:max-w-7xl px-5 xl:px-0 flex flex-col sm:flex-row justify-center items-center gap-12 sm:gap-10 lg:gap-16.75 py-20"
>
  <div class="flex flex-col justify-center items-start gap-10 w-full sm:w-[55%]">
    <div class="flex flex-col justify-center items-start gap-4">
      <div class="py-1 px-3 flex justify-center items-center rounded-2xl bg-secondary/10 animation-right">
        <p class="text-primary text-[14px] font-semibold leading-[150%] uppercase text-center">
          {content.tag}
        </p>
      </div>
      <h2
        class="text-primary text-[32px] sm:text-[48px] lg:text-[56px] font-medium leading-[110%] capitalize font-title animation-right"
        set:html={content.title}
      />
      <p
        class="text-primary text-[14px] font-normal leading-[150%] w-full lg:w-[70%] animation-right"
        set:html={content.description}
      />
    </div>
    <div class="animation-right">
      <Button
      text={content.button.label}
      href={content.button.href}
      extraBtnClass={content.button.bgColor}
      textClass={content.button.textColor}
    />
    </div>
    
  </div>
  <div class="relative overflow-hidden rounded-3xl aspect-508/448 w-full sm:w-[45%] h-auto animation-left">
    <img
      src="/images/advice.webp"
      alt="Advice Image Steve Premium"
      width="508"
      height="448"
      class="w-full h-full object-cover absolute inset-0 object-center"
    />
  </div>
</section>
