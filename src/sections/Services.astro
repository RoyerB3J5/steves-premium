---
type Translations = typeof import('../i18n/en').default;
type ServicesContent = Translations['servicesPage']['services'];
interface Props {
  content: ServicesContent;
}
const { content } = Astro.props as Props;

// Obtener la ruta actual y normalizar el path sin prefijo de idioma
const currentPath = Astro.url.pathname;

// Detectar el idioma actual ('en' o 'es')
const match = currentPath.match(/^\/(en|es)/);
const lang = match ? match[1] : 'en';
---
<section class="w-full flex justify-center items-center bg-secondary/5">
  <div class="w-full max-w-screen xl:max-w-7xl px-5 xl:px-0 py-20 flex flex-col sm:flex-row justify-center items-center gap-6">
    {
      content.map((item,index)=>( 
        <a href={`/${lang}/services/${item.href}`} class={`w-full sm:w-1/2 h-auto aspect-588/471 cursor-pointer hover:-translate-y-2 transition-all duration-300 ease-in-out ${index == 0 ? 'animation-up' : 'animation-down'}`}>
          <div class="h-full flex flex-col justify-center items-start gap-4  rounded-3xl relative px-8 lg:px-15.5 overflow-hidden">
            <img src={`/images/${item.image}.webp`} alt={item.title} width="700" height="391" class="absolute w-full h-full -z-20 inset-0 object-cover object-center top-0 left-0">
            <div class="w-full h-full back-estimate absolute -z-10 top-0 left-0"></div>
            <div class="bg-[#001845] py-1 px-3 rounded-2xl flex justify-center items-center gap-2.5">
              <p class="text-white text-[14px] font-semibold leading-[150%] uppercase">{item.tag}</p>
            </div>
            <h2 class="text-accent text-[32px] font-bold leading-[150%] capitalize">{item.title}</h2>
            <p class="text-white text-[14px] font-normal leading-[150%]S">{item.description}</p>
          </div>
        </a>
        
      ))
    }
  </div>
</section>