---
import CarouselReviews from "../../components/CarouselReviews.astro";

type Translations = typeof import("../../i18n/en").default;
type ReviewsContent = Translations["main"]["review"];
interface Props {
  content: ReviewsContent;
}
const { content } = Astro.props as Props;
---

<section class="w-full flex justify-center items-center bg-secondary/5">
  <div
    class="w-full max-w-screen xl:max-w-7xl px-5 xl:px-0 flex flex-col justify-center items-center gap-12 md:gap-16 py-20 lg:py-30"
  >
    <div class="flex flex-col justify-center items-center gap-4 animation-down">
      <h2
        class="text-primary text-[32px] sm:text-[48px] lg:text-[56px] font-medium leading-[110%] capitalize font-title text-center"
        set:html={content.title}
      />
      <div class="w-21.5 h-1.5 rounded-sm animation-color-shift"></div>
    </div>
    <CarouselReviews content={content} />
    <div class="flex flex-col md:flex-row justify-center items-center gap-6 md:gap-8 w-full animation-zoom">
      {
        content.button.map((item) => (
          <a href={item.href} class="w-full md:w-auto">
            <button
              class={`w-full md:w-auto flex justify-center items-center gap-3.5 box-border   py-4 px-6 rounded-lg cursor-pointer hover:-translate-y-1.25 transition-all duration-300 ease-in-out group ${item.back}`}
            >
              <p class="text-white text-[14px] font-semibold leading-[150%] uppercase transition-all duration-300 ease-in-out">
                {item.label}
              </p>
              <img src="/images/arrow-b.svg" alt="Flecha" width="16" height="16" class="w-4 h-auto" />
            </button>
          </a>
        ))
      }
    </div>
  </div>
</section>
