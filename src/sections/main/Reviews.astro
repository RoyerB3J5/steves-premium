---
type Translations = typeof import('../../i18n/en').default;
type ReviewsContent = Translations['main']['review'];
interface Props {
  content: ReviewsContent;
}
const { content } = Astro.props as Props;
---
<section class="w-full flex justify-center items-center bg-secondary/5">
  <div class="w-full max-w-screen xl:max-w-7xl px-5 xl:px-0 flex flex-col justify-center items-center gap-16 py-30">
    <div class="flex flex-col justify-center items-center gap-4">
      <h2 class="text-primary text-[56px] font-medium leading-[110%] capitalize font-title text-center" set:html={content.title}></h2>
      <div class="w-21.5 h-1.5 rounded-sm bg-secondary"></div>
    </div>
    <div class="grid grid-cols-4 justify-center items-start gap-6">
      {
        content.items.map((item)=>( 
          <div class="w-full flex flex-col justify-start items-start gap-6 rounded-3xl bg-white p-8 h-full">
            <div class="w-full flex justify-between items-center">
              <div class="flex justify-center items-center gap-1">
                {
                  Array(5).fill(0).map((_)=>(
                    <img src="/images/star.svg" alt="star" width="20" height="20" class="w-4 h-auto"/>
                  ))
                }
              </div>
              <img src="/images/google.svg" alt="Google logo" width="20" height="20" class="w-6 h-auto"/>
            </div>
            <p class="text-paragraph text-[14px] italic font-normal leading-[150%] h-full">{item.content}</p>
            <div class="flex justify-start items-center gap-2">
              <div class={`${item.back} w-8 h-8 rounded-full flex justify-center items-center`}>
                <p class="text-[14px] font-bold uppercase leading-[150%] text-white">{item.name[0]}</p>
              </div>
              <div class="flex flex-col justify-center items-start">
                <p class="text-[14px] text-primary font-semibold leading-[150%]">{item.name}</p>
                <p class="text-paragraph text-[10px] font-normal leading-[150%]">{item.time}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
    <a href={content.button.href}>
      <button class="flex justify-center items-center gap-3.5 box-border border-b-2 border-accent py-2 cursor-pointer hover:-translate-y-1.25 transition-all duration-300 ease-in-out group">
        <p class="text-primary text-[14px] font-semibold leading-[150%] uppercase  transition-all duration-300 ease-in-out">{content.button.label}</p>
        <img src="/images/arrow.svg" alt="Flecha" width="16" height="16" class="w-4 h-auto"/>
      </button>
    </a>
  </div>
</section>