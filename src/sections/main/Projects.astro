---
import { Icon } from "astro-icon/components";
import Button from "../../components/Button.astro";
import CarouselProjects from "../../components/CarouselProjects.astro";

type Translations = typeof import("../../i18n/en").default;
type ProjectsContent = Translations["main"]["projects"];
interface Props {
  content: ProjectsContent;
}
const { content } = Astro.props as Props;
---

<section
  class="w-full max-w-screen xl:max-w-7xl px-5 xl:px-0 flex flex-col justify-center items-center gap-20 md:gap-30 py-20 md:py-30"
>
  <div class="flex flex-col justify-center items-center gap-16 w-full">
    <div
      class="w-full flex flex-col md:flex-row justify-between items-start md:items-center gap-8 md:gap-0 animation-down"
    >
      <h2
        set:html={content.title}
        class="text-primary font-title text-[32px] sm:text-[48px] lg:text-[56px] font-medium leading-[110%] capitalize"
      />
      <Button
        text={content.button.label}
        href={content.button.href}
        extraBtnClass={content.button.bgColor}
        textClass={content.button.textColor}
      />
    </div>
    <CarouselProjects content={content} />
  </div>
  <div class="w-full flex flex-col justify-center items-center gap-6 animation-zoom">
    <div class="w-full flex justify-start items-center gap-4">
      <div class="h-13 w-13 rounded-full bg-[#F6F7F8] flex justify-center items-center">
        <img src="/images/user.svg" alt="Icono de Usuario" width="32" height="32" class="w-8 h-8" />
      </div>
      <div class="flex flex-col justify-center items-start gap-2">
        <h3 class="text-primary text-[14px] font-bold leading-[150%]">@stevespressurewash</h3>
        <p class="text-paragraph text-[14px] font-normal leading-[150%]">
          {content.mediaDescription}
        </p>
      </div>
    </div>
    <a
      href="https://www.instagram.com/p/C7Vz_e1Mqwl/?hl=en"
      class="bg-[#408bd1] py-1 px-4 text-[16px] text-white flex items-center gap-2 rounded-[5px] hover:-translate-y-1 transition-all duration-300 ease-in-out"
    >
      <img
        src="/images/instagram.svg"
        alt="Icono de Instagram"
        width="20"
        height="20"
        class="w-4 h-4"
      />
      <p class="text-[14px]">
        {content.socialMedia}
      </p>
    </a>
  </div>
</section>
