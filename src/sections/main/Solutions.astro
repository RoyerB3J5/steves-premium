---
import SolutionsContent from "../../components/SolutionsContent.astro";

type Translations = typeof import("../../i18n/en").default;
type SolutionsContent = Translations["main"]["solutions"];
interface Props {
  content: SolutionsContent;
}
const { content } = Astro.props as Props;
---

<section
  class="w-full flex flex-col justify-center items-center py-20 max-w-screen xl:max-w-7xl px-5 xl:px-0 gap-20 md:gap-24"
>
  <div
    class="w-full flex flex-col md:flex-row justify-center items-center gap-12 md:gap-6 lg:gap-14"
  >
    <div class="w-full md:w-[52%] flex flex-col justify-center items-start gap-12 md:gap-10">
      <div class="w-full flex flex-col justify-center items-start gap-4">
        <div class="py-1 px-3 flex justify-center items-center rounded-2xl bg-secondary/10 animation-right">
          <p class="text-primary text-[14px] font-semibold leading-[150%] uppercase text-center">
            {content.section1.tag}
          </p>
        </div>
        <h2
          class="text-primary text-[32px] sm:text-[48px] lg:text-[56px] font-medium leading-[120%] md:leading-[110%] capitalize font-title animation-right"
          set:html={content.section1.title}
        />
      </div>
      <div
        class="flex flex-col md:flex-row justify-center items-start lg:items-center gap-4 md:gap-2 lg:gap-10 animation-right"
      >
        {
          content.section1.items.map((item) => (
            <div class="flex justify-center items-start lg:items-center gap-4">
              <div class="w-10 h-10 rounded-lg bg-secondary/10 flex justify-center items-center shrink-0">
                <img
                  src={`/images/${item.icons}.svg`}
                  alt={item.title}
                  width="48"
                  height="48"
                  class="w-6 h-auto"
                />
              </div>
              <div class="flex flex-col justify-center items-start min-w-0">
                <h3 class="text-primary text-[14px] font-bold leading-[150%] uppercase ">
                  {item.title}
                </h3>
                <p class="text-paragraph text-[14px] leading-[150%] font-normal ">
                  {item.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
    <div
      class="w-full md:w-[48%] flex flex-col justify-center items-start gap-4 py-6 md:py-5 lg:py-13.75 px-4 lg:px-12 bg-secondary/5 border border-secondary/15 rounded-3xl animation-left"
    >
      <h3 class="text-primary text-[16px] md:text-[20px] font-bold leading-[150%] capitalize">
        {content.section1.description.title}
      </h3>
      <p class="text-paragraph text-[14px] leading-[150%] font-normal">
        {content.section1.description.content}
      </p>
      <div class="grid gap-x-4 gap-y-2 grid-cols-2 lg:grid-cols-3">
        {
          content.section1.description.items.map((item) => (
            <div class="py-1 px-2 bg-white rounded-2xl flex justify-start items-center gap-2 w-auto">
              <img src="/images/check-2.svg" alt="Check" width="24" height="24" class="w-6 h-6" />
              <p class="text-paragraph text-[14px] font-normal leading-[150%]">{item}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
  <div class="flex flex-col justify-center items-center gap-16">
    <SolutionsContent content={content.section2} />
  </div>
</section>
