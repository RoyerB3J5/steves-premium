---
type Translations = typeof import("../../i18n/en").default;
type NumbersContent = Translations["main"]["numbers"];
interface Props {
  content: NumbersContent;
}
const { content } = Astro.props as Props;
---

<section class="w-full flex justify-center items-center bg-primary">
  <div
    class="w-full flex flex-col justify-center items-center gap-16 max-w-screen xl:max-w-7xl px-5 xl:px-0 py-20 lg:py-30"
  >
    <div class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        content.items.map((item, index) => (
          <div class="flex flex-col justify-center items-center gap-2 animation-up"
          style={`animation-delay: ${index * 0.2}s`}>
            <h3 class="text-accent font-title text-[48px] font-medium leading-[110%] capitalize text-center">
              {item.number}
            </h3>
            <p class="text-center text-white text-[14px] font-semibold leading-[150%] uppercase">
              {item.title}
            </p>
            <p class="text-center text-white text-[14px] font-normal leading-[150%] ">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>
    <div class="w-full h-auto aspect-343/385 md:aspect-1200/494 relative rounded-2xl overflow-hidden animation-zoom">
      <img
        src="/images/maps.webp"
        alt="Mapa de cobertura de Steve's Premium Pressure Washing"
        width="1280"
        height="1280"
        class="w-full h-full object-cover object-center absolute inset-0"
        decoding="async"
        loading="lazy"
      />
    </div>
  </div>
</section>
