---
import Button from '../../components/Button.astro';

type Translations = typeof import('../../i18n/en').default;
type AdviceContent = Translations['main']['information']['advice'];
interface Props {
  content: AdviceContent;
}
const { content } = Astro.props as Props;
---
<div class="flex flex-col md:flex-row justify-center items-center gap-12 md:gap-8 lg:gap-13.5">
  <div class="flex flex-col justify-center items-start gap-10 w-full md:w-[45%] animation-right">
    <div class="flex flex-col justify-center items-start gap-6 md:gap-4">
      <h2 class="text-primary text-[32px] sm:text-[48px] lg:text-[56px] font-medium leading-[110%] capitalize font-title" set:html={content.title}></h2>
      <p class="text-paragraph text-[14px] font-normal leading-[150%] w-[90%]" set:html={content.description}></p>
    </div>
    <Button text={content.button.label} href={content.button.href} extraBtnClass={content.button.bgColor} textClass={content.button.textColor}/>
  </div>
  <div class="relative overflow-hidden rounded-3xl aspect-636/448 w-full md:w-[55%] h-auto animation-zoom">
    <img src="/images/advice.webp" alt="Advice Image Steve Premium" width="588" height="448" class="w-full h-full object-cover absolute inset-0 object-center"/>
  </div>
</div>