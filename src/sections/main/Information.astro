---
import Advice from './Advice.astro';
import Process from './Process.astro';

type Translations = typeof import('../../i18n/en').default;
type InformationContent = Translations['main']['information'];
interface Props {
  content: InformationContent;
}
const { content } = Astro.props as Props;
---
<section class="w-full flex justify-center items-center bg-secondary/5">
  <div class="w-full max-w-screen xl:max-w-7xl px-5 xl:px-0 flex flex-col justify-center items-center gap-30 py-30">
    <Process content={content.process}/>
    <Advice content={content.advice}/>
  </div>
</section>