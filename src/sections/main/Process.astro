---
type Translations = typeof import('../../i18n/en').default;
type ProcessContent = Translations['main']['information']['process'];
interface Props {
  content: ProcessContent;
}
const { content } = Astro.props as Props;
---
<div class="flex flex-col justify-center items-center gap-16">
  <div class="flex flex-col justify-center items-center gap-4">
    <h2 class="text-primary text-[56px] font-medium leading-[110%] capitalize font-title text-center" set:html={content.title}></h2>
    <div class="w-21.5 h-1.5 rounded-sm bg-secondary"></div>
  </div>
  <div class="w-full bg-white flex justify-center items-center border border-[#E3E8F0] rounded-3xl divide-x divide-[#E3E8F0]">
    {
      content.items.map((item)=>(
        <div class="w-1/3 flex flex-col justify-center items-center px-10 py-8 gap-6">
          <div class="py-1 px-3 flex justify-center items-center rounded-2xl bg-secondary/10 ">
            <p class="text-primary text-[14px] font-semibold leading-[150%] uppercase text-center">{item.step}</p>
          </div>
          <div class="w-20 h-20 flex justify-center items-center bg-secondary/10 rounded-lg">
            <img src={`/images/${item.icon}.svg`} alt={item.title} width="40" height="40" class="h-10 w-auto">
          </div>
          <div class="flex flex-col justify-center items-center gap-2">
            <h3 class="text-primary text-[14px] font-bold leading-[150%]">{item.title}</h3>
            <p class="text-paragraph text-[14px] font-normal leading-[150%] text-center">{item.description}</p>
          </div>
        </div>
      ))
    }
  </div>
</div>