---
type Translations = typeof import('../../i18n/en').default;
type ContactContent = Translations['main']['contact'];
interface Props {
  content: ContactContent;
}
const { content } = Astro.props as Props;
---
<section class="w-full max-w-screen xl:max-w-7xl px-5 xl:px-0 flex justify-center items-center gap-6 pt-15 pb-30">
  <div class="flex flex-col justify-center items-center gap-10 w-1/2">
    <div class="flex flex-col justify-center items-start gap-4">
      <div class="py-1 px-3 flex justify-center items-center rounded-2xl bg-secondary/10 ">
        <p class="text-primary text-[14px] font-semibold leading-[150%] uppercase text-center">{content.tag}</p>
      </div>
      <h2 set:html={content.title} class="text-primary text-[56px] font-medium leading-[110%] capitalize font-title text-start"></h2>
      <p class="text-paragraph text-[14px] font-normal leading-[150%] text-start">{content.description}</p>
    </div>
    <div class="rounded-3xl relative overflow-hidden aspect-588/716 w-full h-auto">
      <img src="/images/form.webp" alt="Imagen de formulario" width="419" height="750" class="absolute object-cover object-top inset-0 w-full h-full">
    </div>
  </div>
  <div class="w-1/2 h-full bg-secondary rounded-3xl">

  </div>
</section>